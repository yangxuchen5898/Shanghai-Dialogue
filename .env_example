# Audio
SAMPLE_RATE=16000
CHANNELS=1
FRAME_MS=20
AUDIO_FORMAT=paInt16

# VAD
VAD_MODE=2
VAD_WINDOW_FRAMES=25
VAD_SPEECH_RATIO_THRESHOLD=0.4
END_SILENCE_FRAMES=35

# Paths
UTTERANCE_DIR=runtime/utterances
TEMP_DIR=runtime/temp

# ASR
SENSEVOICE_MODEL_DIR=models/sensevoice
ASR_DEVICE=cpu
ASR_LANGUAGE=zh

# Qwen LLM
QWEN_API_KEY=your_api_key
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=30

# TTS
TTS_SAMPLE_RATE=24000
TTS_VOICE=zh-CN-XiaoxiaoNeural
